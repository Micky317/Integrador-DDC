{
  "expo": {
    "name": "DDC-Check Pasitos Firmes",
    "slug": "ddc-check",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#090D1F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ddccheck.pasitosfirmes"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#090D1F",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "package": "com.ddccheck.pasitosfirmes"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "DDC-Check necesita acceso a tu galería para cargar radiografías.",
          "cameraPermission": "DDC-Check necesita acceso a la cámara para capturar ecografías."
        }
      ],
      "expo-asset"
    ],
    "scheme": "ddc-check"
  }
}
